{
  "version": "1.0.0",
  "description": "趋势跟踪 Agent 配置文件（用户可通过对话动态修改）",

  "scanner": {
    "enabled": true,
    "symbols": [
      "SHFE.rb", "SHFE.hc", "SHFE.ru", "SHFE.ni", "SHFE.cu",
      "DCE.jm", "DCE.j", "DCE.i", "DCE.p", "DCE.y", "DCE.cs",
      "CZCE.CF", "CZCE.SR", "CZCE.TA", "CZCE.MA",
      "INE.sc", "INE.lu"
    ],
    "schedule": ["08:40", "15:20", "20:40"],
    "heartbeat": {
      "enabled": true,
      "interval_minutes": 5,
      "trading_hours": {
        "day_session": ["09:00-11:30", "13:30-15:00"],
        "night_session": ["21:00-23:00"]
      }
    },
    "signal_filter": {
      "filter_mode": "or",
      "er_min": 0.6,
      "tsi_min": 20,
      "tsi_max": -20,
      "trend_strength_min": 0.5,
      "r2_min": 0.4
    },
    "multi_dimension": {
      "enabled": true,
      "comment": "五维度筛选评分: trend(30%) + momentum(25%) + volume(20%) + volatility(15%) + channel(10%). 需先运行 sync_indicators.py 填充 DuckDB indicators 表.",
      "signal_thresholds": {
        "long": 0.3,
        "short": -0.3
      }
    },
    "output_path": "data/latest_scan.json"
  },

  "monitor": {
    "enabled": true,
    "interval_minutes": 30,
    "data_source": "data/positions.json",
    "alert_thresholds": {
      "LOW": {
        "trend_strength_drop": 0.15
      },
      "MEDIUM": {
        "trend_strength_drop": 0.25,
        "tsi_divergence": true
      },
      "HIGH": {
        "trend_strength_drop": 0.35,
        "er_below": 0.3
      }
    },
    "output_path": "data/latest_monitor.json"
  },

  "reasoner": {
    "llm_type": "workbuddy",
    "debate_trigger_confidence": 0.7,
    "max_tokens_per_day": 500000
  },

  "llm": {
    "provider": "auto",
    "model": "mimo-v2.5-pro",
    "base_url": "https://token-plan-cn.xiaomimimo.com/v1",
    "api_key_env": "LLM_API_KEY",
    "temperature": 0.7,
    "max_tokens": 2000,
    "note": "provider=auto 时，系统优先使用宿主平台的 LLM；设置 LLM_API_KEY 后使用自定义 LLM"
  },

  "debater": {
    "enabled": true,
    "trigger_conditions": {
      "confidence_below": 0.7,
      "position_value_above": 50000
    }
  },

  "evolver": {
    "enabled": true,
    "auto_trigger": {
      "consecutive_losses": 3,
      "cumulative_loss_pct": 10,
      "trade_count_interval": 20
    }
  },

  "token_budget": {
    "daily_limit": 850000,
    "warn_at_pct": 80,
    "stop_at_pct": 100
  },

  "data_routing": {
    "description": "统一数据路由层配置 — 按数据类型设置数据源优先级",
    "db_dir": "data",
    "priorities": {
      "kline":       ["duckdb", "tqsdk", "pytdx", "csv"],
      "quote":       ["duckdb", "tqsdk", "pytdx"],
      "basis":       ["akshare", "pytdx"],
      "seasonality": ["akshare", "csv"],
      "inventory":   ["akshare"]
    },
    "staleness_threshold": {
      "kline": 4,
      "quote": 0.5,
      "basis": 24,
      "seasonality": 168,
      "inventory": 24
    }
  },

  "data_retention": {
    "scan_history_days": 30,
    "brief_history_days": 90,
    "log_days": 7
  }
}
