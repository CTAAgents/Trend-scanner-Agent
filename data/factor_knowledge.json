    {
      "id": "factor_002",
      "name": "波动率收缩因子",
      "code": "def factor(df: pd.DataFrame) -> pd.Series:\n    \"\"\"\n    因子名称：波动率收缩因子\n    因子描述：识别波动率收缩后的突破机会\n    逻辑：ATR收缩比率 * 价格突破强度\n    \n    Args:\n        df: 包含 OHLCV 数据的 DataFrame\n        \n    Returns:\n        pd.Series: 因子值，index 与输入 df 相同\n    \"\"\"\n    import pandas as pd\n    import numpy as np\n    \n    # 计算 ATR\n    high_low = df['high'] - df['low']\n    high_close = np.abs(df['high'] - df['close'].shift())\n    low_close = np.abs(df['low'] - df['close'].shift())\n    true_range = pd.concat([high_low, high_close, low_close], axis=1).max(axis=1)\n    atr = true_range.rolling(14).mean()\n    \n    # 计算 ATR 收缩比率\n    atr_ratio = atr / atr.rolling(50).mean()\n    \n    # 计算价格突破强度\n    price_breakout = (df['close'] - df['close'].rolling(20).mean()) / df['close'].rolling(20).std()\n    \n    # 计算因子值\n    factor_value = (1 - atr_ratio) * price_breakout\n    \n    # 归一化\n    factor_value = factor_value / factor_value.abs().max()\n    \n    return factor_value",
      "description": "识别波动率收缩后的突破机会",
      "logic": "ATR收缩比率 * 价格突破强度",
      "source": "market_context",
      "performance": {
        "ic": 0.04,
        "icir": 1.0,
        "stability": 0.7,
        "sharpe": 1.2
      },
      "regime_effectiveness": {
        "trending": 0.8,
        "ranging": 0.5,
        "volatile": 0.4
      },
      "created_at": "2026-06-15 17:00:00",
