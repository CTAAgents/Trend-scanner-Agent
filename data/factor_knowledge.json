    {
      "id": "factor_003",
      "name": "RSI超卖反弹因子",
      "code": "def factor(df: pd.DataFrame) -> pd.Series:\n    \"\"\"\n    因子名称：RSI超卖反弹因子\n    因子描述：捕捉RSI超卖后的反弹机会\n    逻辑：RSI超卖信号 * 成交量确认\n    \n    Args:\n        df: 包含 OHLCV 数据的 DataFrame\n        \n    Returns:\n        pd.Series: 因子值，index 与输入 df 相同\n    \"\"\"\n    import pandas as pd\n    import numpy as np\n    \n    # 计算 RSI\n    delta = df['close'].diff()\n    gain = (delta.where(delta > 0, 0)).rolling(window=14).mean()\n    loss = (-delta.where(delta < 0, 0)).rolling(window=14).mean()\n    rs = gain / loss\n    rsi = 100 - (100 / (1 + rs))\n    \n    # RSI 超卖信号\n    oversold_signal = (rsi < 30).astype(int)\n    \n    # 成交量确认\n    volume_confirmation = df['volume'] / df['volume'].rolling(20).mean()\n    \n    # 计算因子值\n    factor_value = oversold_signal * volume_confirmation\n    \n    # 归一化\n    factor_value = factor_value / factor_value.abs().max()\n    \n    return factor_value",
      "description": "捕捉RSI超卖后的反弹机会",
      "logic": "RSI超卖信号 * 成交量确认",
      "source": "market_context",
      "performance": {
        "ic": 0.03,
        "icir": 0.8,
        "stability": 0.6,
        "sharpe": 1.0
